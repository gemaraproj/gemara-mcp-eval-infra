# Container runtime: docker or podman
CONTAINER_RUNTIME=docker

# The gemara-mcp image to evaluate against.
# In CI this is set by the upstream pipeline (e.g. registry/gemara-mcp:sha-abc123).
# Locally, pull or build the image and set this value accordingly.
GEMARA_MCP_IMAGE=ghcr.io/gemaraproj/gemara-mcp:v0.1.0

GEMARA_MCP_MODE=artifact
